
# 데이터베이스 설정

# 데이터베이스 (MySQL 루트 비밀번호 입력)
DATABASE_URL=

# JWT 시크릿 (강력한 무작위 문자열)
JWT_SECRET=


# 로컬 로그인만 사용 (OAuth 비활성화)
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID="local"

# 분석 (Analytics ) - 필수
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID="local"

# 앱 정보
VITE_APP_TITLE="Bumjin Chat"
VITE_APP_LOGO="/logo.png"

# 포트
PORT=3001

# OpenAI API (나중에 설정)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

OWNER_OPEN_ID="admin"
OWNER_NAME="Admin"
